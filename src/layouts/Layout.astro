---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Supports weights 400-700
import '@fontsource-variable/dancing-script';
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import Preloader from "../components/Preloader.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/butterfly.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>15 Clara</title>
  </head>
  <body  class="relative text-black dark:text-white">
    <Preloader/>
    <div class="absolute inset-0 -z-10 w-full h-full min-h-screen px-5 [background:linear-gradient(to_right,#54ccac_0%,#141414_50%,#54ccac_100%)]"></div>
    
    <Header/>
     <Hero 
    title="Clara" 
    subtitle="Mis 15 años"
    bgImage="https://placehold.co/1440x990.png" />

    
    <slot />
    <Footer/>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
  }

  html {
    scroll-behavior: smooth;
    font-family: 'Dancing Script Variable', cursive;
    
    font-size: 130%;
    /* font-family: "Onest Variable", system-ui, sans-serif; */
	scroll-padding-top: 125px; 
  }

  body {
    background: #1f1f1f;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  @media (prefers-reduced-motion: reduce) {
    body {
      scroll-behavior: auto;
    }
  }
</style>